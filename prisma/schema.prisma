generator client {
  provider            = "prisma-client"
  output              = "../generated/prisma"
  importFileExtension = ""
  previewFeatures     = ["views", "fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName       String?
  lastName        String?
  email           String?  @unique
  image           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
  profile         Profile?
  reportsCreated  Report[] @relation("ReportsCreated")
  reportsReceived Report[] @relation("ReportsReceived")
  blocksCreated   Block[]  @relation("BlocksCreated")
  blocksReceived  Block[]  @relation("BlocksReceived")
}

model Profile {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userType              UserType?
  userId                String        @unique @db.Uuid
  bio                   String?
  locationId            Int?
  occupationId          Int?
  updatedAt             DateTime      @default(now())
  gender                Gender?
  sameGenderPref        Boolean?
  linkedInUrl           String?
  githubUrl             String?
  buyMeCoffeeUrl        String?
  yearsOfExperience     Int?
  calendlyUserUri       String?       @unique
  onboardingCompleted   Boolean       @default(false)
  isAcceptingMentees    Boolean       @default(true)
  onVacation            Boolean       @default(false)
  vacationEndsAt        DateTime?
  monthlyCapacity       Int?
  location              Location?     @relation(fields: [locationId], references: [id])
  occupation            Occupation?   @relation(fields: [occupationId], references: [id])
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendlyUser          CalendlyUser?
  skills                Skill[]       @relation("ProfileSkills")
  mentorSessions        Session[]     @relation("MentorSessions")
  menteeSessions        Session[]     @relation("MenteeSessions")
  menteeRequests        MentorshipRequest[] @relation("MenteeRequests")
  mentorRequests        MentorshipRequest[] @relation("MentorRequests")
  nudgesSent            MenteeNudge[]       @relation("MentorNudgesSent")
  nudgesReceived        MenteeNudge[]       @relation("MenteeNudgesReceived")
}

model Location {
  id      Int       @id @default(autoincrement())
  city    String?
  country String?
  profile Profile[]

  @@unique([city, country])
}

model Occupation {
  id      Int       @id @default(autoincrement())
  role    String?
  company String?
  profile Profile[]

  @@unique([role, company])
}

model CalendlyUser {
  uri                  String   @id
  profileId            String   @unique @db.Uuid
  name                 String?
  slug                 String?
  email                String?
  scheduling_url       String?  @unique
  timezone             String?
  avatar_url           String?
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now())
  current_organization String?
  resource_type        String?
  accessToken          String?
  refreshToken         String?
  webhookUri           String?
  profile              Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Session {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  calendlyEventUri String        @unique
  eventName        String?
  startTime        DateTime
  endTime          DateTime
  status           SessionStatus @default(ACTIVE)
  mentorProfileId  String        @db.Uuid
  mentorProfile    Profile       @relation("MentorSessions", fields: [mentorProfileId], references: [id], onDelete: Cascade)
  menteeProfileId  String        @db.Uuid
  menteeProfile    Profile       @relation("MenteeSessions", fields: [menteeProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  canceledAt       DateTime?
}

enum SessionStatus {
  ACTIVE
  CANCELED
}

model MentorshipRequest {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menteeProfileId String                  @db.Uuid
  mentorProfileId String                  @db.Uuid
  message         String
  status          MentorshipRequestStatus @default(PENDING)
  lastNudgedAt    DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  menteeProfile   Profile                 @relation("MenteeRequests", fields: [menteeProfileId], references: [id], onDelete: Cascade)
  mentorProfile   Profile                 @relation("MentorRequests", fields: [mentorProfileId], references: [id], onDelete: Cascade)

  @@unique([menteeProfileId, mentorProfileId])
}

enum MentorshipRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model MenteeNudge {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentorProfileId String   @db.Uuid
  menteeProfileId String   @db.Uuid
  lastNudgedAt    DateTime @default(now())
  mentorProfile   Profile  @relation("MentorNudgesSent", fields: [mentorProfileId], references: [id], onDelete: Cascade)
  menteeProfile   Profile  @relation("MenteeNudgesReceived", fields: [menteeProfileId], references: [id], onDelete: Cascade)

  @@unique([mentorProfileId, menteeProfileId])
}

model Report {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId  String       @db.Uuid
  reportedId  String       @db.Uuid
  reason      ReportReason
  description String?
  status      ReportStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewedBy  String?      @db.Uuid
  createdAt   DateTime     @default(now())
  reporter    User         @relation("ReportsCreated", fields: [reporterId], references: [id], onDelete: Cascade)
  reported    User         @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId])
  @@index([status])
}

model Block {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blockerId String   @db.Uuid
  blockedId String   @db.Uuid
  createdAt DateTime @default(now())
  blocker   User     @relation("BlocksCreated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

enum ReportReason {
  HARASSMENT
  SPAM
  INAPPROPRIATE_CONTENT
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

model Skill {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  category String?
  profiles Profile[] @relation("ProfileSkills")
}

view MentorProfile {
  id                    String    @unique
  userType              UserType?
  firstName             String?
  lastName              String?
  bio                   String?
  image                 String?
  calendlySchedulingUrl String?
  gender                Gender?
  sameGenderPref        Boolean?
  city                  String?
  country               String?
  role                  String?
  yearsOfExperience     Int?
  company               String?
  linkedInUrl           String?
  githubUrl             String?
  buyMeCoffeeUrl        String?
  skills                String[]
  sessionCount          Int       @default(0)
  memberSince           DateTime?
  isAcceptingMentees    Boolean   @default(true)
  onVacation            Boolean   @default(false)
  vacationEndsAt        DateTime?
  monthlyCapacity       Int?
}

enum UserType {
  MENTOR
  MENTEE
}

enum Gender {
  MALE
  FEMALE
}
